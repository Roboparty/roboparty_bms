@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(fmt)
find_dependency(spdlog)

include("${CMAKE_CURRENT_LIST_DIR}/roboparty_bmsTargets.cmake")

if(NOT TARGET roboparty_bms::roboparty_bms)
    add_library(roboparty_bms::roboparty_bms INTERFACE IMPORTED)
    target_link_libraries(roboparty_bms::roboparty_bms INTERFACE 
        roboparty_bms::bms
        roboparty_bms::tws_bms
        roboparty_bms::gf_bms
    )
endif()

check_required_components(roboparty_bms)
